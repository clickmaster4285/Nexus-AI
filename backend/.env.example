#  SERVER
PORT=3000
NODE_ENV=development

#  MONGODB
#  Replace with your MongoDB connection string
MONGO_URI=mongodb://localhost:27017/pbx_crm

#  ASTERISK AMI (Asterisk Manager Interface)
#  These must match what you set in manager.conf
AMI_HOST=192.168.1.100        # IP of your FreePBX server
AMI_PORT=5038                  # Default AMI port
AMI_USERNAME=crmuser           # AMI username from manager.conf
AMI_PASSWORD=yourSecretPassword # AMI password from manager.conf

#  CALL RECORDINGS
#  Path where FreePBX saves recordings
RECORDINGS_PATH=/var/spool/asterisk/monitor
RECORDINGS_BASE_URL=http://your-server-ip:3000/recordings

#  SECURITY
ALLOWED_ORIGINS=http://localhost:3001,http://your-crm-frontend-url.com
